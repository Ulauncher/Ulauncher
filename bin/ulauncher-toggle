#!/bin/sh

# Print $1 to stderr, wrapped in yellow ANSI SGR when stderr is a TTY.
warn() {
  if [ -t 2 ]; then
    printf '\033[33m%s\033[0m\n' "$1" >&2
  else
    printf '%s\n' "$1" >&2
  fi
}

while [ "$#" -gt 0 ]
do
  arg="$1"
  shift
  if [ "$arg" = "--query" ] || [ "$arg" = "-q" ]; then
    if [ "$#" -eq 0 ]; then
      printf '%s\n' 'ulauncher-toggle: missing value for --query/-q' >&2
      exit 2
    fi
    warn "ulauncher-toggle is deprecated. Use \`ulauncher show \"$1\"\` instead."
    escaped_query=$(printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e "s/'/\\\\'/g")
    gapplication action io.ulauncher.Ulauncher set-query "'$escaped_query'"
    exit 0
  fi
done

warn 'ulauncher-toggle is deprecated. Use `ulauncher toggle` instead.'
gapplication action io.ulauncher.Ulauncher toggle-window
